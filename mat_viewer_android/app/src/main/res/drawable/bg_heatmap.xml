<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <stroke android:color="@color/sub500" android:width="4dp"/>
            <solid android:color="#2F3034"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>

    <item android:top="2dp" android:bottom="2dp" android:left="22dp" android:right="22dp">
        <shape android:shape="line">
            <stroke android:color="@color/sub500_30" android:width="1dp" android:dashWidth="8dp" android:dashGap="8dp"/>
        </shape>
    </item>

    <item android:gravity="center" android:left="22dp" android:right="22dp">
        <rotate
            android:fromDegrees="90"
            android:toDegrees="90"
            android:pivotX="50%"
            android:pivotY="50%"
            android:drawable="@drawable/line_dash_horizontal" />
    </item>

</layer-list>